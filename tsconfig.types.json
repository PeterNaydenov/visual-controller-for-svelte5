{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "./dist",
    "emitDeclarationOnly": true,
    "allowJs": true,
    "checkJs": false,
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "strict": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noImplicitAny": false
  },
  "include": ["src/main.js"]
}
