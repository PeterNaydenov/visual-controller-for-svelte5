{
  "name": "@peter.naydenov/visual-controller-svelte5",
  "description": "Tool for building a micro-frontends(MFE) based on Svelte 5 components",
  "version": "1.1.0",
  "license": "MIT",
  "author": "Peter Naydenov",
  "main": "src/main.js",
  "types": "dist/main.d.ts",
  "module": "src/main.js",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./src/main.js",
      "require": "./dist/visualController-svelte-5.cjs"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run types",
    "types": "tsc -p tsconfig.types.json",
    "cover": "vitest run --coverage",
    "test": "vitest run"
  },
  "dependencies": {
    "ask-for-promise": "^3.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@vitest/browser": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "svelte": "^5.56.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "fsevents@2.3.3": true,
    "fsevents@2.3.2": true
  }
}
